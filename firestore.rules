rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Safety Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // MATCH BLOCKS FOR COLLECTIONS
    match /users/{userId} {
      allow read, write: if isSignedIn() && isValidId(userId);
    }

    match /suppliers/{supplierId} {
      allow read, write: if isSignedIn() && isValidId(supplierId);
    }

    match /purchases/{purchaseId} {
      allow read, write: if isSignedIn() && isValidId(purchaseId);
    }

    match /payments/{paymentId} {
      allow read, write: if isSignedIn() && isValidId(paymentId);
    }

    match /logs/{logId} {
      allow read, write: if isSignedIn() && isValidId(logId);
    }

    match /system_config/{configId} {
      allow read, write: if isSignedIn() && isValidId(configId);
    }
  }
}
